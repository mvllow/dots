theme = dark:rose-pine-noir,light:rose-pine-dawn

adjust-cell-height = 30%
font-family = Berkeley Mono
font-size = 13.5

background-opacity = 0.97
background-blur = true

confirm-close-surface = false

cursor-style-blink = false
mouse-hide-while-typing = true

macos-option-as-alt = false
macos-titlebar-style = hidden
window-padding-balance = true

# tmux-compatible keybinds
# \x02 is ctrl+b (default tmux prefix)
# \x01 is ctrl+a (common alternative tmux prefix)
keybind = super+w=text:\x01x
keybind = super+t=text:\x01c
keybind = super+comma=text:\x01,
keybind = super+shift+left_bracket=text:\x01p
keybind = super+shift+right_bracket=text:\x01n
keybind = super+d=text:\x01d
keybind = super+s=text:\x01s
keybind = super+shift+l=text:\x01L
keybind = super+f=text:\x01f
keybind = super+g=text:\x01g
keybind = super+shift+g=text:\x01G
