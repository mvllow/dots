theme = rose-pine-dawn
command = "/opt/homebrew/bin/tmux new -A"

adjust-cell-height = 40%
font-family = SF Mono
font-size = 13.5
window-decoration = true
window-padding-balance = true

cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true
shell-integration-features = no-cursor

confirm-close-surface = false

# Keybinds
# \x02 is ctrl+b (default tmux prefix)
# \x01 is ctrl+a (common alternative tmux prefix)
keybind = super+one=text:\x011
keybind = super+two=text:\x012
keybind = super+three=text:\x013
keybind = super+four=text:\x014
keybind = super+w=text:\x01x
keybind = super+t=text:\x01c
keybind = super+comma=text:\x01,
keybind = super+shift+left_bracket=text:\x01p
keybind = super+shift+right_bracket=text:\x01n
keybind = super+d=text:\x01d
keybind = super+s=text:\x01s
keybind = super+shift+l=text:\x01L
keybind = super+f=text:\x01f
keybind = super+g=text:\x01g
keybind = super+shift+g=text:\x01G
