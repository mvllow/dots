syntax off

set autoindent expandtab
set shiftwidth=4 softtabstop=4 tabstop=4

set hlsearch ignorecase incsearch smartcase

set noswapfile
set undofile
set undodir=~/.vim/undo
set undolevels=9999
set viminfo=""

set hidden
set laststatus=0
set splitbelow splitright

inoremap jk <esc>
nnoremap k gk
nnoremap j gj