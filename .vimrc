syntax off

set autoindent expandtab
set shiftwidth=2 softtabstop=2 tabstop=2

set hlsearch ignorecase incsearch smartcase

set noswapfile
set undofile
set undodir=~/.vim/undo
set undolevels=9999
set viminfo=""

set hidden
set laststatus=1
set splitbelow splitright

inoremap jk <esc>
nnoremap k gk
nnoremap j gj